---
import BaseLayout from "../layouts/BaseLayout.astro";
import { questions, solutions, siteMeta, banks } from "../lib/dataset.js";
const dataPayload = JSON.stringify({ questions, solutions, siteMeta, banks });
---

<BaseLayout title="Topic Roadmap - Elite IGCSE Mathematics">
  <div class="container section">
    <header class="page-head card royale-frame">
      <div>
        <span class="meta eyebrow">Topic Roadmap</span>
        <h1>Pick the exact topic you want to master.</h1>
        <p>Browse every topic, see how much practice exists, and jump straight into a filtered question set.</p>
      </div>
      <div class="hero-stats">
        <span><strong data-roadmap-total>0</strong>Total questions</span>
        <span><strong data-roadmap-topics>0</strong>Visible topics</span>
        <span><strong data-roadmap-solved>0</strong>Solved</span>
      </div>
    </header>

    <section class="controls card">
      <label><span class="label">Search topic</span><input class="input" type="search" placeholder="Circle theorems, surds..." data-roadmap-search /></label>
      <label><span class="label">Chapter / unit</span><select class="select" data-roadmap-unit></select></label>
      <label><span class="label">Bank</span><select class="select" data-roadmap-bank>
        <option value="all">All classified</option>
        <option value="expertise">Q20+ expertise</option>
      </select></label>
      <label><span class="label">Progress</span><select class="select" data-roadmap-progress>
        <option value="">All topics</option>
        <option value="unsolved">Needs practice</option>
        <option value="started">Started</option>
        <option value="complete">Completed</option>
      </select></label>
    </section>

    <section class="guide">
      <article class="card"><strong>1. Choose a topic</strong><p>Start with a weak area or follow the course order.</p></article>
      <article class="card"><strong>2. Solve before checking</strong><p>Use the worked solution after you genuinely try.</p></article>
      <article class="card"><strong>3. Build a set</strong><p>Use Practice to print or save a focused worksheet.</p></article>
    </section>

    <section class="roadmap-grid" data-roadmap-grid aria-live="polite"></section>
  </div>

  <script is:inline define:vars={{ dataPayload }}>
    const payload = JSON.parse(dataPayload);
    window.QUESTION_DATA = payload.questions;
    window.SOLUTION_DATA = payload.solutions;
    window.SITE_META = payload.siteMeta;
    window.BANK_META = payload.banks;
  </script>
  <script is:inline>
    (function () {
      const mode = localStorage.getItem("elitePathway") || "linear";
      window.ELITE_PATHWAY = { mode, isModular: mode === "modular" };
    })();
  </script>
  <script is:inline src="/scripts/topic-normalizer.js"></script>
  <script is:inline defer src="/scripts/topics-app.js"></script>
</BaseLayout>

<style>
  .page-head {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: var(--space-3);
    align-items: center;
  }
  .page-head h1 { margin-bottom: var(--space-1); }
  .page-head p { color: var(--muted); max-width: 62ch; }
  .eyebrow { display: block; margin-bottom: 6px; text-transform: uppercase; font-size: 11px; }
  .hero-stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(110px, 1fr));
    gap: var(--space-1);
  }
  .hero-stats span {
    display: grid;
    gap: 2px;
    padding: var(--space-2);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--ivory);
    color: var(--muted);
    text-align: center;
  }
  .hero-stats strong { color: var(--navy); font-size: 24px; }
  .controls {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--space-2);
    margin-top: var(--space-3);
  }
  .guide {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-2);
    margin-top: var(--space-3);
  }
  .guide p { margin-top: 6px; color: var(--muted); }
  .roadmap-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: var(--space-2);
    margin-top: var(--space-3);
  }
  .roadmap-card {
    display: grid;
    gap: var(--space-2);
  }
  .roadmap-head h2 { font-size: var(--type-h3); margin-top: 4px; }
  .roadmap-meter {
    height: 8px;
    border-radius: var(--radius-full);
    background: var(--line);
    overflow: hidden;
  }
  .roadmap-meter span {
    display: block;
    height: 100%;
    background: var(--gold);
  }
  .roadmap-stats {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 6px;
    font-size: 12px;
    color: var(--muted);
  }
  .roadmap-stats span {
    display: grid;
    gap: 2px;
    padding: 8px;
    border-radius: var(--radius-sm);
    background: var(--ivory);
    text-align: center;
  }
  .roadmap-stats strong { color: var(--navy); font-size: 18px; }
  .roadmap-actions { display: flex; flex-wrap: wrap; gap: var(--space-1); }
  .empty-card {
    padding: var(--space-3);
    border: 1px dashed var(--line-strong);
    border-radius: var(--radius);
    background: var(--paper);
    color: var(--muted);
  }
  @media (max-width: 860px) {
    .page-head,
    .controls,
    .guide { grid-template-columns: 1fr; }
  }
</style>
