<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Offline - Elite IGCSE Mathematics</title>
    <meta name="theme-color" content="#0B1F3A" />
    <style>
      :root {
        --navy: #0B1F3A;
        --gold: #C9A24B;
        --ivory: #FBF8F2;
        --paper: #FFFFFF;
        --line: #D1C8AE;
        --muted: #6B7383;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
        background: var(--ivory);
        color: var(--navy);
        font-family: Arial, Helvetica, sans-serif;
      }
      main {
        width: min(680px, calc(100vw - 32px));
        padding: 32px;
        border: 1px solid var(--line);
        border-radius: 16px;
        background: var(--paper);
      }
      span {
        display: block;
        margin-bottom: 8px;
        color: var(--muted);
        text-transform: uppercase;
      }
      h1 { margin: 0 0 12px; }
      p { color: var(--muted); line-height: 1.5; }
      nav {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 20px;
      }
      a {
        padding: 10px 14px;
        border: 1px solid var(--navy);
        border-radius: 8px;
        color: var(--navy);
        text-decoration: none;
      }
      a:first-child {
        border-color: var(--gold);
        background: var(--gold);
      }
    </style>
  </head>
  <body>
    <main>
      <span>Offline</span>
      <h1>You are offline, but the study habit can continue.</h1>
      <p>Open a page you visited before, or reconnect to load new questions, papers, and solutions.</p>
      <nav>
        <a href="/notes">Notes</a>
        <a href="/practice">Practice</a>
        <a href="/pastpapers/">Past papers</a>
      </nav>
    </main>
  </body>
</html>
